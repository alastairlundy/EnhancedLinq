<Project>
  <PropertyGroup>
    <!-- Enable central package management, https://learn.microsoft.com/en-us/nuget/consume-packages/Central-Package-Management -->
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>
  <PropertyGroup>
    <!-- default false, CI can set to true -->
    <UsePublishedPackages Condition="'$(UsePublishedPackages)'==''">false</UsePublishedPackages>
  </PropertyGroup>
  <ItemGroup>
    <PackageVersion Include="Microsoft.Extensions.Primitives" Version="10.0.9" />
    <PackageVersion Include="DotExtensions.Memory" Version="10.3.3" />
    <PackageVersion Include="DotExtensions" Version="10.3.3" />
    <PackageVersion Include="Meziantou.Analyzer" Version="3.0.122">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageVersion>
    <PackageVersion Include="Polyfill" Version="10.11.2" PrivateAssets="all" />
    <PackageVersion Include="System.Linq.AsyncEnumerable" Version="10.0.9" Condition="'$(TargetFramework)' == 'netstandard2.0' OR '$(TargetFramework)' == 'net8.0' OR '$(TargetFramework)' == 'net9.0'" />
    <PackageVersion Include="Microsoft.Bcl.AsyncInterfaces" Version="10.0.9" Condition="'$(TargetFramework)' == 'netstandard2.0'" />
  </ItemGroup>
  <ItemGroup>
    <PackageVersion Include="Bogus" Version="35.6.5" />
    <PackageVersion Include="TUnit" Version="1.53.0" />
  </ItemGroup>
  <ItemGroup Condition="'$(UsePublishedPackages)'=='true'">
    <!-- set EnhancedLinqVersion in the workflow -->
    <PackageVersion Include="EnhancedLinq" Version="$(EnhancedLinqVersion)" />
  </ItemGroup>
</Project>